--- 
import type { MarkdownHeading } from "astro";  
  
import ForumSidebarProfileCard from "@/components/forum/ForumSidebarProfileCard.svelte";  
import Profile from "./Profile.astro";  
  
interface Props {  
	headings?: MarkdownHeading[];  
	isForumRoute?: boolean;  
}  
  
const isForumRoute = Astro.props.isForumRoute ?? false;  
const forumBasePath = "/forum/";  
---  
  
<div id="sidebar" class="w-full" data-forum-base-path={forumBasePath}>  
    <div class="flex flex-col w-full gap-4 mb-4">  
        <div id="sidebar-profile-blog" class:list={[{ hidden: isForumRoute }]}>  
            <Profile></Profile>  
        </div>  
        <div id="sidebar-profile-forum" class:list={[{ hidden: !isForumRoute }]}>  
            <ForumSidebarProfileCard client:load />  
        </div>  
    </div>  
</div>
