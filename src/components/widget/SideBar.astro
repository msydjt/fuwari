---
import type { MarkdownHeading } from "astro";

import ForumSidebarProfileCard from "@/components/forum/ForumSidebarProfileCard.svelte";
import {
	buildTimetableViewModel,
	resolveCurrentWeek,
} from "@/utils/timetable-normalizer";
import { parseTimetableFile } from "@/utils/timetable-parser-server";
import { url } from "@/utils/url-utils";
import LiveTimetableStatus from "@components/timetable/LiveTimetableStatus.astro";
import Profile from "./Profile.astro";

interface Props {
	headings?: MarkdownHeading[];
	isForumRoute?: boolean;
}

const isForumRoute = Astro.props.isForumRoute ?? false;
const forumBasePath = url("/forum/");

const timetableData = parseTimetableFile("src/data/timetable/大一下2.json");
const timetableWeek = resolveCurrentWeek(
	timetableData.meta.startDate,
	timetableData.meta.maxWeek,
);
const timetableViewModel = buildTimetableViewModel(
	timetableData,
	timetableWeek,
);
const sidebarLiveStatusPayload = {
	coursesByDay: timetableViewModel.coursesByDay,
};
---

<div id="sidebar" class="w-full" data-forum-base-path={forumBasePath}>
    <div class="flex flex-col w-full gap-4 mb-4">
        <div id="sidebar-profile-blog" class:list={[{ hidden: isForumRoute }]}>
            <Profile></Profile>
        </div>
        <div id="sidebar-profile-forum" class:list={[{ hidden: !isForumRoute }]}>
            <ForumSidebarProfileCard client:load />
        </div>
    </div>
    <div id="sidebar-sticky" class="transition-all duration-700 flex flex-col w-full gap-4 top-4 sticky top-4" style="top: calc(var(--navbar-offset, 0px) + 1rem);">

        <div id="sidebar-deepwiki" class:list={[{ hidden: isForumRoute }]}>
            <a href="https://deepwiki.com/afoim/fuwari" target="_blank" rel="noopener noreferrer"
               class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-[var(--card-bg)] border-2 border-[var(--primary)] text-[var(--primary)] font-bold text-lg hover:bg-[var(--primary)] hover:text-white transition-all shadow-md active:scale-95 group">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform">
                    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
                </svg>
                有疑问？询问 DeepWiki！
            </a>
        </div>

    </div>
</div>

